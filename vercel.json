{
  "version": 2,
  "buildCommand": "pnpm install && cd apps/api && npx prisma generate && npx nest build && cd ../.. && pnpm --filter web build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/dist/**,apps/api/node_modules/.prisma/**,node_modules/.prisma/**",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
