{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/dist/**,node_modules/.prisma/**,node_modules/@prisma/**",
      "memory": 512,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
