{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run vercel-build",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "includeFiles": "apps/api/dist/**,node_modules/.prisma/**",
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
