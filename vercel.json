{
  "version": 2,
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["apps/api/dist/**", "node_modules/.prisma/**"]
      }
    },
    {
      "src": "apps/web/dist/**",
      "use": "@vercel/static"
    }
  ],
  "buildCommand": "pnpm install && cd apps/api && npx prisma generate && npx nest build && cd ../.. && pnpm --filter web build",
  "outputDirectory": "apps/web/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path]" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
