{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile"
  },
  "deploy": {
    "startCommand": "cd apps/api && npx prisma migrate deploy && node dist/main",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
